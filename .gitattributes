# Default: auto-detect text; normalize checkouts to LF.
* text=auto eol=lf

# Source & config — explicit LF
*.py          text eol=lf
*.md          text eol=lf
*.yaml        text eol=lf
*.yml         text eol=lf
*.json        text eol=lf
*.toml        text eol=lf
*.cfg         text eol=lf
*.ini         text eol=lf
*.txt         text eol=lf
*.j2          text eol=lf
*.jinja       text eol=lf

# Windows-only scripts & installer — CRLF
*.ps1         text eol=crlf
*.bat         text eol=crlf
*.cmd         text eol=crlf
*.iss         text eol=crlf

# Binary assets — no text processing
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.pdf         binary
*.zip         binary
*.7z          binary
*.exe         binary
*.dll         binary
*.so          binary
*.dylib       binary
*.db          binary
*.sqlite      binary
*.traineddata binary

# Vendored installer binaries
installer/vendor/** binary
